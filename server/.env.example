# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/raahi

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Email (for OTP verification & password reset) - using SMTP, e.g. Mailtrap/Gmail/SendGrid
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
FROM_EMAIL=noreply@raahi.com
FROM_NAME=RAAHI

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
